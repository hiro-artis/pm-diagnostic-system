# Claude API Configuration
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Database (optional for Cloud SQL)
DATABASE_URL=postgresql://user:password@cloud-sql-proxy-host:5432/pm_diagnostic

# Frontend URL (for CORS)
FRONTEND_URL=https://pm-diagnostic.vercel.app

# Environment
ENVIRONMENT=production

# Logging
LOG_LEVEL=INFO

# Port (default 8080 for Cloud Run)
PORT=8080

# Session
SESSION_TIMEOUT=3600
