# Ignore git files
.git
.gitignore

# Ignore Python cache
__pycache__
*.py[cod]
*$py.class
.Python
*.egg-info/
dist/
build/

# Ignore virtual environments
.venv/
venv/
ENV/
env/

# Ignore IDE
.vscode/
.idea/
