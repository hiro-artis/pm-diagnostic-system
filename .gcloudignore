.env
.env.local
.env.*.local

# Ignore test data
data/results/
.pytest_cache/
.coverage

# Ignore Node modules (if any frontend build)
node_modules/
.next/

# Ignore documentation
docs/
*.md

# Ignore misc
.DS_Store
.terraform/
